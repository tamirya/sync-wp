{
  "name": "typescript-express-mongoose-starter",
  "version": "1.1.7",
  "private": false,
  "description": "TypeScript + Express + Sequelize + MySQL",
  "license": "ISC",
  "author": "Ahmad Joya",
  "bin": {
    "typescript-express-mongoose-starter": "./bin/cli.js"
  },
  "scripts": {
    "start": "npm run build && cross-env NODE_ENV=production node dist/server.js",
    "dev": "cross-env NODE_ENV=development nodemon",
    "db:sync": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register --transpile-only src/scripts/sync-db.ts",
    "db:sync:safe": "cross-env NODE_ENV=development DB_SYNC_ALTER=false ts-node -r tsconfig-paths/register --transpile-only src/scripts/sync-db.ts",
    "db:sync:category-rules": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register --transpile-only src/scripts/sync-category-rules.ts",
    "db:sync:product-category-rules": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register --transpile-only src/scripts/sync-product-category-rules.ts",
    "db:sync:catalog": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register --transpile-only src/scripts/sync-catalog.ts",
    "db:sync:categories": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register --transpile-only src/scripts/sync-categories.ts",
    "build": "swc src -d dist --source-maps --copy-files",
    "build:tsc": "tsc && tsc-alias",
    "test": "jest --forceExit --detectOpenHandles",
    "lint": "eslint --ignore-path .gitignore --ext .ts src/",
    "lint:fix": "npm run lint -- --fix",
    "deploy:prod": "npm run build && pm2 start ecosystem.config.js --only prod",
    "deploy:dev": "pm2 start ecosystem.config.js --only dev",
    "postinstall": "npx husky install",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@woocommerce/woocommerce-rest-api": "^1.0.2",
    "bcrypt": "^5.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "envalid": "^7.3.1",
    "express": "^4.18.1",
    "helmet": "^5.1.1",
    "hpp": "^0.2.3",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "jsonwebtoken": "^8.5.1",
    "morgan": "^1.10.0",
    "mysql2": "^3.22.0",
    "playwright": "^1.49.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.1",
    "swagger-ui-express": "^4.5.0",
    "winston": "^3.8.1",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@swc/cli": "^0.1.57",
    "@swc/core": "^1.2.220",
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.7.2",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/hpp": "^0.2.2",
    "@types/jest": "^28.1.6",
    "@types/jsonwebtoken": "^8.5.8",
    "@types/morgan": "^1.9.3",
    "@types/node": "^17.0.45",
    "@types/supertest": "^2.0.12",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.20.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.1",
    "jest": "^28.1.1",
    "lint-staged": "^13.0.3",
    "node-config": "^0.0.2",
    "node-gyp": "^9.1.0",
    "nodemon": "^2.0.19",
    "pm2": "^5.2.0",
    "prettier": "^2.7.1",
    "supertest": "^6.2.4",
    "ts-jest": "^28.0.7",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.7.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^4.7.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadjoya/typescript-express-mongoose-starter.git"
  },
  "keywords": [
    "TypeScript",
    "Express",
    "ExpressJS",
    "express.js",
    "mongoose",
    "typescript express",
    "typescript express mongoose",
    "starter",
    "boilerplate",
    "typescript express mongooses tarter",
    "typescript-express-mongooses-tarter"
  ],
  "bugs": {
    "url": "https://github.com/ahmadjoya/typescript-express-mongoose-starter/issues"
  },
  "homepage": "https://github.com/ahmadjoya/typescript-express-mongoose-starter#readme"
}
